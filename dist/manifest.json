{
  "manifest_version": 3,
  "name": "Syndrax Sync",
  "version": "1.0.0",
  "description": "Multi-channel eCommerce automation by Syndrax LLC",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.ebay.com/*",
    "*://*.amazon.com/*",
    "*://*.aliexpress.com/*",
    "https://discord.com/*",
    "*://*.walmart.com/*",
    "*://*.homedepot.com/*",
    "*://*.temu.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Syndrax Sync",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/ebay-mesh-order-overlay.ts-loader-a3371eb2.js",
        "assets/customer-message-tool.ts-4ed993c7.js"
      ],
      "matches": [
        "*://*.ebay.com/mesh/ord/details*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-order-extractor.ts-87d4c536.js"
      ],
      "matches": [
        "*://*.ebay.com/ord/*",
        "*://*.ebay.com/sh/ord/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/amazon-price-checker.ts-09266909.js",
        "assets/amazon-scraper.ts-cb9e63c1.js",
        "assets/sniper-overlay.ts-a233e7bb.js"
      ],
      "matches": [
        "*://*.amazon.com/dp/*",
        "*://*.amazon.com/gp/product/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/sniper-overlay.ts-a233e7bb.js"
      ],
      "matches": [
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.co.uk/gp/product/*",
        "https://www.amazon.de/dp/*",
        "https://www.amazon.de/gp/product/*",
        "https://www.amazon.ca/dp/*",
        "https://www.amazon.ca/gp/product/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/amazon-fulfillment.ts-loader-bd64dfee.js"
      ],
      "matches": [
        "*://*.amazon.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/aliexpress-price-checker.ts-dbf94a29.js"
      ],
      "matches": [
        "*://*.aliexpress.com/item/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/aliexpress-fulfillment.ts-e7692e87.js"
      ],
      "matches": [
        "*://*.aliexpress.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-sync-controller.ts-loader-8caa417e.js",
        "assets/listing-optimizer.ts-4ed993c7.js"
      ],
      "matches": [
        "*://*.ebay.com/sh/lst/*",
        "*://*.ebay.com/sh/lst*",
        "*://*.ebay.com/mys/active*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-listing-creator.ts-64e7f279.js"
      ],
      "matches": [
        "*://*.ebay.com/sl/sell*",
        "*://*.ebay.com/sell/create*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/competitor-research.ts-e97e1858.js"
      ],
      "matches": [
        "*://*.ebay.com/sch/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-ebay-scanner.ts-5c7dc805.js"
      ],
      "matches": [
        "*://*.ebay.com/mys/sold*",
        "*://*.ebay.com/sh/ord/*sold*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-ebay-payment.ts-loader-61513f80.js"
      ],
      "matches": [
        "*://*.ebay.com/mes/transactiondetails*",
        "*://*.ebay.com/mesh/pmt/details*",
        "*://*.ebay.com/mesh/ord/details*",
        "*://*.ebay.com/payments/paymentSummary*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-amazon-orders.ts-loader-f7505502.js"
      ],
      "matches": [
        "*://*.amazon.com/gp/your-account/order-history*",
        "*://*.amazon.com/your-orders*",
        "*://*.amazon.com/gp/css/order-history*"
      ],
      "run_at": "document_end"
    }
  ],
