{
  "manifest_version": 3,
  "name": "Syndrax Sync",
  "version": "1.0.0",
  "description": "Multi-channel eCommerce automation by Syndrax LLC",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.ebay.com/*",
    "*://*.amazon.com/*",
    "*://*.aliexpress.com/*",
    "https://discord.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Syndrax Sync"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/ebay-mesh-order-overlay.ts-loader-86f68fd4.js"
      ],
      "matches": [
        "*://*.ebay.com/mesh/ord/details*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-order-extractor.ts-5b6dda91.js"
      ],
      "matches": [
        "*://*.ebay.com/ord/*",
        "*://*.ebay.com/sh/ord/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/amazon-price-checker.ts-09266909.js",
        "assets/amazon-scraper.ts-cb9e63c1.js"
      ],
      "matches": [
        "*://*.amazon.com/dp/*",
        "*://*.amazon.com/gp/product/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/amazon-fulfillment.ts-loader-a53d1f03.js"
      ],
      "matches": [
        "*://*.amazon.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/aliexpress-price-checker.ts-dbf94a29.js"
      ],
      "matches": [
        "*://*.aliexpress.com/item/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/aliexpress-fulfillment.ts-e8af6fd4.js"
      ],
      "matches": [
        "*://*.aliexpress.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-sync-controller.ts-c7c08818.js"
      ],
      "matches": [
        "*://*.ebay.com/sh/lst/*",
        "*://*.ebay.com/sh/lst*",
        "*://*.ebay.com/mys/active*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/ebay-listing-creator.ts-da16a0e4.js"
      ],
      "matches": [
        "*://*.ebay.com/sl/sell*",
        "*://*.ebay.com/sell/create*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/competitor-research.ts-31764ce4.js"
      ],
      "matches": [
        "*://*.ebay.com/sch/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-ebay-scanner.ts-10c83193.js"
      ],
      "matches": [
        "*://*.ebay.com/mys/sold*",
        "*://*.ebay.com/sh/ord/*sold*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-ebay-payment.ts-loader-d6ff7c38.js"
      ],
      "matches": [
        "*://*.ebay.com/mes/transactiondetails*",
        "*://*.ebay.com/mesh/pmt/details*",
        "*://*.ebay.com/mesh/ord/details*",
        "*://*.ebay.com/payments/paymentSummary*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "assets/finance-amazon-orders.ts-loader-7ebbe814.js"
      ],
      "matches": [
        "*://*.amazon.com/gp/your-account/order-history*",
        "*://*.amazon.com/your-orders*",
        "*://*.amazon.com/gp/css/order-history*"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.ebay.com/*"
      ],
      "resources": [
        "button1.mp3"
